# Mobile env. Read at build time automatically by Expo for vars prefixed with EXPO_PUBLIC_
# HUMAN_ACTION_REQUIRED: replace with your machine's LAN IP when testing on a real device.
EXPO_PUBLIC_API_BASE=http://192.168.1.42:4000

# Firebase configuration
EXPO_PUBLIC_FIREBASE_USE_EMULATOR=false
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyDemoEmulatorKey
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=pethub-local.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=pethub-local
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
