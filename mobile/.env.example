# Mobile env. Read at build time automatically by Expo for vars prefixed with EXPO_PUBLIC_
# Android emulator: use 10.0.2.2 to reach the host machine.
# Real device: replace with your machine's LAN IP (e.g. 192.168.1.42).
EXPO_PUBLIC_API_BASE=http://10.0.2.2:4000

# Firebase configuration
# Set to true when running the Firebase local emulator suite.
EXPO_PUBLIC_FIREBASE_USE_EMULATOR=true
# Auth emulator host — Android emulator: 10.0.2.2; real device: your machine's LAN IP.
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://10.0.2.2:9099
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyDemoEmulatorKey
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=pethub-local.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=pethub-local
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Stripe Configuration
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
