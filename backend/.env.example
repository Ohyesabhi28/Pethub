# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# Firebase — emulator mode (default for MVP)
FIREBASE_USE_EMULATOR=true
FIREBASE_PROJECT_ID=pethub-local
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Firebase — only needed if FIREBASE_USE_EMULATOR=false
# HUMAN_ACTION_REQUIRED: paste service account values here for production-style runs
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# RAG service
RAG_SERVICE_URL=http://127.0.0.1:5000
RAG_TIMEOUT_MS=15000

# Seeding
SEED_ON_BOOT=true
